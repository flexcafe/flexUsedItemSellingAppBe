# Database (Supabase PostgreSQL)
DATABASE_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT_REF].supabase.co:5432/postgres"

# Supabase
SUPABASE_URL="https://[PROJECT_REF].supabase.co"
SUPABASE_SERVICE_KEY="your-supabase-service-role-key"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
JWT_EXPIRATION="7d"

# App
PORT=3000
NODE_ENV=development
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:5173"

# Email (Brevo SMTP)
BREVO_SMTP_HOST="smtp-relay.brevo.com"
BREVO_SMTP_PORT=587
BREVO_SMTP_USER="your-brevo-smtp-login"
BREVO_SMTP_PASS="your-brevo-smtp-password"
BREVO_FROM_EMAIL="no-reply@example.com"
BREVO_FROM_NAME="FlexCafe"

# SMS (SMSPoh API v3 — REST send: https://smspoh.com/v3/developers/restful-sms-api-specification )
SMSPOH_API_KEY="your-smspoh-v3-api-key"
SMSPOH_API_SECRET="your-smspoh-v3-api-secret"
SMSPOH_SENDER_ID="YourSenderId"
# Optional: default https://v3.smspoh.com/api/rest
# SMSPOH_API_BASE_URL="https://v3.smspoh.com/api/rest"
# Set to "true" to send test messages only (SMSPoh `test` flag)
# SMSPOH_TEST="false"

# Root admin (seed)
ROOT_ADMIN_EMAIL="admin@example.com"
ROOT_ADMIN_PASSWORD="change-me"
ROOT_ADMIN_PHONE="+959000000000"
ROOT_ADMIN_NICKNAME="Root Admin"
